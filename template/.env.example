# ─────────────────────────────────────────────────────────────────
# REQUIRED — bring your own LLM key.
# OpenRouter free tier works for testing; sign up at openrouter.ai.
# ─────────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=

# ─────────────────────────────────────────────────────────────────
# DEFAULTS — leave as-is unless you have a reason to change.
# ─────────────────────────────────────────────────────────────────

# Cheap, capable, ~$0.10/M input tokens.
HERMES_MODEL=openrouter/z-ai/glm-4.5-air

# cli   — talk in your terminal (default; recommended for first run)
# telegram — bot delivers digests to a Telegram chat (set vars below)
RUN_MODE=cli

# ─────────────────────────────────────────────────────────────────
# BUDGET GUARD
# Hard cap on USD spend per session and per cron run. When the cap
# is hit, the agent finishes the current memo and exits cleanly.
# Allowed range: 0.10 – 5.00
# ─────────────────────────────────────────────────────────────────
BUDGET_USD_PER_SESSION=1.00
BUDGET_ENFORCED=true

# ─────────────────────────────────────────────────────────────────
# OPTIONAL — Telegram delivery (only if RUN_MODE=telegram)
# Create a bot via @BotFather (90 seconds). Then DM your bot once
# and run `make telegram-chat-id` to get TELEGRAM_ALLOWED_USER_ID.
# ─────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USER_ID=

# ─────────────────────────────────────────────────────────────────
# OPTIONAL — output paths (relative to /app inside the container)
# ─────────────────────────────────────────────────────────────────
MEMO_DIR=out/memos
FEEDBACK_DIR=out/feedback
DIGEST_DIR=out/digest
